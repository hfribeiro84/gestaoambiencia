# =====================================================================
# Backend — Sistema de Gestão Ambiência
# Copie este arquivo para `.env` e preencha. NUNCA versione o `.env`.
# =====================================================================

# Servidor
PORT=3333
# Origem do frontend liberada no CORS (em produção: URL do Vercel)
FRONTEND_URL=http://localhost:5173

# --- Supabase -------------------------------------------------------
# Pegue em: Supabase > Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=cole-a-anon-key-aqui
# service_role: acesso total ao banco (ignora RLS). SÓ no backend, nunca no frontend.
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui

# --- Claude (Anthropic) --------------------------------------------
ANTHROPIC_API_KEY=cole-a-api-key-aqui
CLAUDE_MODELO_RAPIDO=claude-haiku-4-5-20251001
CLAUDE_MODELO_AVANCADO=claude-sonnet-4-6

# --- Pipedrive (API token) -----------------------------------------
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_DOMINIO=https://SUA-EMPRESA.pipedrive.com

# --- Clockify (API key) --------------------------------------------
CLOCKIFY_API_KEY=
CLOCKIFY_WORKSPACE_ID=

# --- Conta Azul (OAuth 2.0) — DUAS contas: ASS e NETR ---------------
CONTA_AZUL_ASS_CLIENT_ID=
CONTA_AZUL_ASS_CLIENT_SECRET=
CONTA_AZUL_NETR_CLIENT_ID=
CONTA_AZUL_NETR_CLIENT_SECRET=
# Redirect base do backend (em produção: URL do Railway)
CONTA_AZUL_REDIRECT_BASE=http://localhost:3333

# --- Google Drive (OAuth 2.0) --------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_BASE=http://localhost:3333
