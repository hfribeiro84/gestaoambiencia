# =====================================================================
# Frontend — Sistema de Gestão Ambiência
# Copie para `.env` e preencha. Variáveis VITE_* ficam expostas no bundle:
# use SÓ chaves públicas (anon key do Supabase). NUNCA a service_role.
# =====================================================================

# URL da API backend (em produção: URL do Railway)
VITE_API_URL=http://localhost:3333

# Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole-a-anon-key-aqui
